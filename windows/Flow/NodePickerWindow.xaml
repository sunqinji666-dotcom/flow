<Window x:Class="Flow.NodePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择节点" Height="500" Width="340"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Border CornerRadius="16" Background="#E618202B" BorderBrush="#1AFFFFFF" BorderThickness="1" Padding="20,16">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="选择节点" FontSize="18" FontWeight="ExtraBold" Foreground="#F2F7FF" Margin="0,0,0,12"/>
            <ListBox x:Name="NodeListBox" Background="Transparent" BorderThickness="0" SelectionChanged="NodeListBox_SelectionChanged"/>
        </DockPanel>
    </Border>
</Window>
