<Window x:Class="Flow.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="420" Width="340"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Border CornerRadius="16" Background="#E618202B" BorderBrush="#1AFFFFFF" BorderThickness="1" Padding="20,16">
        <StackPanel>
            <TextBlock Text="设置" FontSize="18" FontWeight="ExtraBold" Foreground="#F2F7FF" Margin="0,0,0,16"/>

            <TextBlock Text="节点管理" FontSize="13" FontWeight="ExtraBold" Foreground="#F2F7FF"/>
            <Button Content="更新节点" Margin="0,6,0,12" Padding="0,6" Click="UpdateNodes_Click"/>

            <CheckBox x:Name="SystemProxyCheck" Content="系统代理" Foreground="#F2F7FF" Margin="0,4,0,0" Checked="SystemProxy_Changed" Unchecked="SystemProxy_Changed"/>

            <TextBlock Text="分流策略" FontSize="13" FontWeight="ExtraBold" Foreground="#F2F7FF" Margin="0,12,0,4"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="RbDirect" Content="不代理" Foreground="#B8C8D8" Margin="0,0,8,0" Checked="Routing_Changed"/>
                <RadioButton x:Name="RbBypassCN" Content="绕过大陆" Foreground="#B8C8D8" Margin="0,0,8,0" Checked="Routing_Changed" IsChecked="True"/>
                <RadioButton x:Name="RbLanOnly" Content="绕过局域网" Foreground="#B8C8D8" Margin="0,0,8,0" Checked="Routing_Changed"/>
                <RadioButton x:Name="RbGlobal" Content="全局代理" Foreground="#B8C8D8" Margin="0,0,0,0" Checked="Routing_Changed"/>
            </StackPanel>

            <TextBlock Text="端口 SOCKS5 10606  HTTP 10607" FontSize="10" Foreground="#71859B" Margin="0,14,0,0"/>
            <TextBlock Text="默认不改系统代理，其他软件可手动填端口" FontSize="10" Foreground="#71859B" Margin="0,2,0,0"/>
        </StackPanel>
    </Border>
</Window>
